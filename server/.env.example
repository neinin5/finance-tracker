MONGO_URI=mongodb://localhost:27017/uk_finance_tracker
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
PORT=3000
GOOGLE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/1TV3NqU5uO0h-ilAnRQtNUe0BGGSRrpklKA46QQYBoJA/export?format=csv

# Production: comma-separated list of allowed frontend origins, or * for any.
# Example for Vercel: CORS_ORIGIN=https://uk-finance-tracker.vercel.app
CORS_ORIGIN=*

# Email — optional. If RESEND_API_KEY is empty the email feature is disabled.
# Get a free API key at https://resend.com (100 emails/day on free tier).
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
WEEKLY_SUMMARY_TO=

# Secret for the unauthenticated cron endpoint that triggers the weekly email.
# Sent as `X-Cron-Secret` header. Generate with: openssl rand -hex 32
CRON_SECRET=
